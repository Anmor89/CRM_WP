# Папка с резервными копиями версий — в репозиторий не нужна,
# историю версий хранит сам git. Если хотите хранить и эти файлы —
# удалите строку ниже.
backups/

# Локальные данные 1С — НЕ ПУБЛИЧНЫЕ, в git их быть не должно.
# Сюда можно вручную класть xlsx из Yandex Disk, если поднимаешь
# локальный http-сервер (например, `python -m http.server 8000`).
_data/

# Локальные настройки превью-сервера
.claude/

# Системные файлы
Thumbs.db
desktop.ini
.DS_Store

# Временные файлы редакторов
*.tmp
*~
